# QuantLab AI — Backend Environment Variables
# Copy to .env and fill in production values before deploying.

# ------------------------------------------------------------------ #
# Database                                                             #
# ------------------------------------------------------------------ #
DATABASE_URL=postgresql+psycopg2://apex:apex@localhost:5432/apexquant

# ------------------------------------------------------------------ #
# Security & Auth (REQUIRED in production)                             #
# ------------------------------------------------------------------ #
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_use_a_random_32_byte_hex_string
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=30

# ------------------------------------------------------------------ #
# CORS (leave empty for localhost dev mode)                            #
# ------------------------------------------------------------------ #
# Comma-separated list of allowed origins in production:
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# ------------------------------------------------------------------ #
# Redis (optional; falls back to in-memory cache if not set)          #
# ------------------------------------------------------------------ #
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------ #
# Environment                                                          #
# ------------------------------------------------------------------ #
# Set to "production" to enable strict security controls
ENVIRONMENT=development

# ------------------------------------------------------------------ #
# API metadata                                                         #
# ------------------------------------------------------------------ #
API_TITLE=QuantLab AI — Portfolio Engine
API_VERSION=2.0.0
