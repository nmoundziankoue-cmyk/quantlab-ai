{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/quant/:path*",              "destination": "https://quantlab-ai-2c2i.onrender.com/quant/:path*" },
    { "source": "/m18/:path*",                "destination": "https://quantlab-ai-2c2i.onrender.com/m18/:path*" },
    { "source": "/research/:path*",           "destination": "https://quantlab-ai-2c2i.onrender.com/research/:path*" },
    { "source": "/system/:path*",             "destination": "https://quantlab-ai-2c2i.onrender.com/system/:path*" },
    { "source": "/market/:path*",             "destination": "https://quantlab-ai-2c2i.onrender.com/market/:path*" },
    { "source": "/portfolio/:path*",          "destination": "https://quantlab-ai-2c2i.onrender.com/portfolio/:path*" },
    { "source": "/orchestrator/:path*",       "destination": "https://quantlab-ai-2c2i.onrender.com/orchestrator/:path*" },
    { "source": "/market-intel/:path*",       "destination": "https://quantlab-ai-2c2i.onrender.com/market-intel/:path*" },
    { "source": "/knowledge-graph/:path*",    "destination": "https://quantlab-ai-2c2i.onrender.com/knowledge-graph/:path*" },
    { "source": "/economic-calendar/:path*",  "destination": "https://quantlab-ai-2c2i.onrender.com/economic-calendar/:path*" },
    { "source": "/options/:path*",            "destination": "https://quantlab-ai-2c2i.onrender.com/options/:path*" },
    { "source": "/notifications/:path*",      "destination": "https://quantlab-ai-2c2i.onrender.com/notifications/:path*" },
    { "source": "/auth/:path*",               "destination": "https://quantlab-ai-2c2i.onrender.com/auth/:path*" },
    { "source": "/health",                    "destination": "https://quantlab-ai-2c2i.onrender.com/health" },
    { "source": "/(.*)",                      "destination": "/index.html" }
  ]
}
